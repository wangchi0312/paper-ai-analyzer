LLM_PROVIDER=deepseek
LLM_TEMPERATURE=0.2

RESEARCH_TOPIC=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=

MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=
MODELSCOPE_MODEL=

# 邮箱配置（支持 QQ/163/Outlook/Gmail，自动检测运营商）
EMAIL_ADDRESS=
EMAIL_AUTH_CODE=
# 向后兼容旧变量名（新部署建议使用 EMAIL_ADDRESS / EMAIL_AUTH_CODE）
# QQ_EMAIL=
# QQ_EMAIL_AUTH_CODE=
# 手动指定运营商（不填则自动检测）：qq / 163 / outlook / gmail
# EMAIL_PROVIDER=auto

FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# 出版商 PDF 浏览器下载使用的持久化 profile（可选；默认复用 WoS profile）
PUBLISHER_BROWSER_PROFILE_DIR=
# 出版商下载浏览器通道：auto / chrome / msedge / chromium
# Cloudflare 验证循环时建议优先用 auto 或 chrome，复用真实浏览器通道和持久化 profile。
PUBLISHER_BROWSER_CHANNEL=auto
# 人工验证循环保护秒数；验证页持续不消失超过该时间就跳过当前论文
PUBLISHER_VERIFICATION_LOOP_SECONDS=60

# 全文获取默认使用 SPIS 文献求助；publisher/auto 仅作为显式兜底调试使用
FULL_TEXT_SOURCE=spis
SPIS_BASE_URL=https://spis.hnlat.com/
SPIS_WAIT_MINUTES=30
SPIS_POLL_INTERVAL_SECONDS=60
SPIS_TITLE_MATCH_THRESHOLD=0.82

# 对话式 Agent 新默认：不自动下载全文。保留 SPIS 配置仅用于旧实验链路显式调试。
FULL_TEXT_SOURCE=manual
